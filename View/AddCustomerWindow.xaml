<Window x:Class="Client_Ranker.View.AddCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client_Ranker"
        mc:Ignorable="d"
        Title="AddCustomerWindow" Height="450" Width="800" Background="#FFAFA192">
<Grid Margin="20">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,10">
        <TextBlock Text="DNI / Documento:" FontWeight="Bold" Foreground="#2d3436"/>
        <TextBox Text="{Binding DocumentId}" Padding="5" Margin="0,5,0,0" Background="#FFF3F3F3"/>
    </StackPanel>

    <StackPanel Grid.Row="1" Margin="0,0,0,10">
        <TextBlock Text="Nombre:" FontWeight="Bold" Foreground="#2d3436"/>
        <TextBox Text="{Binding FirstName}" Padding="5" Margin="0,5,0,0" Background="#FFF3F3F3"/>
    </StackPanel>

    <StackPanel Grid.Row="2" Margin="0,0,0,10">
        <TextBlock Text="Apellido:" FontWeight="Bold" Foreground="#2d3436"/>
        <TextBox Text="{Binding LastName}" Padding="5" Margin="0,5,0,0" Background="#FFF3F3F3"/>
    </StackPanel>

    <StackPanel Grid.Row="3" Margin="0,0,0,15">
        <TextBlock Text="Compra ($):" FontWeight="Bold" Foreground="#2d3436"/>
        <TextBox Text="{Binding MonthlySpending}" Padding="5" Margin="0,5,0,0" Background="#FFF3F3F3"/>
    </StackPanel>

    <Button Grid.Row="4" Content="Guardar Cliente" Command="{Binding SaveCommand}" 
            Background="#FF1981D2" Foreground="White" FontWeight="Bold" Height="35"/>
</Grid>
</Window>
