<Window x:Class="Client_Ranker.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client_Ranker"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Background="#FFAFA192">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="73*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Margin="-20,-20,-20,15" Background="#FFE5E5E5" Padding="5,2" Grid.ColumnSpan="2">
            <MenuItem Header="📊 Estadisticas" Command="{Binding OpenDashboardCommand}" />
            <MenuItem Header="⚙️ Configuración de Categorias" Command="{Binding OpenSettingsCommand}" />
            <MenuItem Header="🧪 Test App" Command="{Binding OpenTestCommand}" Foreground="Brown" />
        </Menu>

        <DockPanel Grid.Row="1" Margin="0,0,0,15" Grid.ColumnSpan="2">
            <TextBlock Text="Client Ranker" FontSize="22" FontWeight="Bold" Foreground="#2d3436" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Buscar:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Width="200" Padding="5" Margin="0,0,20,0" VerticalContentAlignment="Center" Background="#FFE5E5E5"/>

                <TextBlock Text="Visualizar período:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <ComboBox SelectedIndex="{Binding SelectedPeriodIndex}" Width="150" Padding="5">
                    <ComboBoxItem Content="Mes Actual"/>
                    <ComboBoxItem Content="Mes Anterior"/>
                </ComboBox>
            </StackPanel>
        </DockPanel>

        <DataGrid Grid.Row="1" x:Name="CustomerGrid" 
                  ItemsSource="{Binding CustomersDisplay}" 
                  SelectedItem="{Binding SelectedCustomer}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  Background="#FFE5E5E5" BorderBrush="#dfe6e9" Grid.ColumnSpan="2" Margin="0,44,0,0" Grid.RowSpan="2">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                            <Setter Property="Background" Value="#f5f6fa"/>
                            <Setter Property="Foreground" Value="#b2bec3"/>
                            <Setter Property="FontStyle" Value="Italic"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="DNI/Documento" Binding="{Binding DocumentId}" Width="120"/>
                <DataGridTextColumn Header="Apellido" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Nombre / Alias" Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Monto Período" Binding="{Binding Spending, StringFormat=C}" Width="120"/>
                <DataGridTextColumn Header="Puntos" Binding="{Binding Points}" Width="80"/>
                <DataGridTextColumn Header="Categoría" Binding="{Binding Category}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,20,0,0" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Cargar Compra" Command="{Binding AddPurchaseCommand}" 
                        Width="120" Height="30" Margin="0,0,10,0" Background="#FF0984E3" Foreground="White" FontWeight="Bold"/>
                <Button Content="Editar Cliente" Command="{Binding EditCustomerCommand}" 
                        Width="120" Height="30" Margin="0,0,10,0" Background="#0984e3" Foreground="White"/>

                <Button Content="Eliminar Cliente" Command="{Binding DeleteCustomerCommand}" 
                        Width="120" Height="30" Margin="10,0,0,0" Background="#d63031" Foreground="White"/>
                <Button Content="Restaurar Cliente" Command="{Binding RestoreCustomerCommand}" 
                        Width="114" Height="30" Margin="10,0,0,0" Background="#FF615350" Foreground="White"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Nuevo Cliente" Command="{Binding OpenAddCustomerCommand}" Width="120" Height="30" Margin="5" 
                        Background="#FF1981D2" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
