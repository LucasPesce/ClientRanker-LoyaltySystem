<Window x:Class="Client_Ranker.View.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Panel de Inteligencia Comercial" Height="600" Width="850"
        WindowStartupLocation="CenterScreen" Background="#FFAFA192">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Resumen del Último Mes Cerrado" FontSize="22" FontWeight="Bold" Foreground="#2d3436" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFE5E5E5" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Total Facturado" Foreground="#636e72" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat=C}" Foreground="#0984e3" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#FFE5E5E5" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Tickets Emitidos" Foreground="#636e72" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalTickets}" Foreground="#00b894" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="#FFE5E5E5" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Ticket Promedio" Foreground="#636e72" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding AverageTicket, StringFormat=C}" Foreground="#d63031" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="15"/>   <ColumnDefinition Width="*"/>    </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFE5E5E5" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Evolución de Ventas (Últimos 6 meses)" FontSize="16" FontWeight="Bold" Foreground="#2d3436" Margin="0,0,0,15"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding RevenueSeries}" XAxes="{Binding XAxes}" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#FFE5E5E5" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Fidelidad Actual" FontSize="16" FontWeight="Bold" Foreground="#2d3436" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <lvc:PieChart Grid.Row="1" Series="{Binding CategorySeries}" LegendPosition="Right" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#FFE0D0AE" CornerRadius="5" Padding="15" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding InsightMessage}" FontSize="14" FontWeight="SemiBold" Foreground="#2d3436" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>