<Window x:Class="Client_Ranker.View.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar parámetros de categorías" Height="420" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#FFAFA192">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Parámetros del Programa" FontSize="18" FontWeight="Bold" Foreground="#2d3436" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Pesos ($) equivalentes a 1 Punto:" FontWeight="Bold" Foreground="#2d3436" Margin="0,0,0,5"/>
            <TextBox Text="{Binding PesosPorPunto}" Padding="5" FontSize="14" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9" Margin="0,0,0,15"/>

            <TextBlock Text="Umbrales de Categoría (Puntos mínimos):" FontWeight="Bold" Foreground="#2d3436" Margin="0,0,0,10"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Text="Plata:" FontWeight="SemiBold" Foreground="#2d3436"/>
                    <TextBox Text="{Binding SilverThreshold}" Padding="5" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                    <TextBlock Text="Oro:" FontWeight="SemiBold" Foreground="#2d3436"/>
                    <TextBox Text="{Binding GoldThreshold}" Padding="5" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Platino:" FontWeight="SemiBold" Foreground="#2d3436"/>
                    <TextBox Text="{Binding PlatinumThreshold}" Padding="5" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="Diamante:" FontWeight="SemiBold" Foreground="#2d3436"/>
                    <TextBox Text="{Binding DiamondThreshold}" Padding="5" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <Button Grid.Row="2" Content="Guardar Cambios" Command="{Binding SaveCommand}" 
                Background="#FF0984E3" Foreground="White" FontWeight="Bold" Height="35"/>
    </Grid>
</Window>