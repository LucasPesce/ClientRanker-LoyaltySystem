<Window x:Class="Client_Ranker.View.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar parámetros de categorías" Height="605" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#FFAFA192">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Configuración del Sistema" FontSize="18" FontWeight="Bold" Foreground="#2d3436" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,38">
            <StackPanel>
                <TextBlock Text="Pesos ($) equivalentes a 1 Punto:" FontWeight="Bold" Foreground="#2d3436" Margin="0,0,0,5"/>
                <TextBox Text="{Binding PesosPorPunto}" Padding="5" FontSize="14" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9" Margin="0,0,0,15"/>
                
                <TextBlock Text="Umbrales de Categoría (Puntos mínimos):" FontWeight="Bold" Foreground="#2d3436" Margin="0,0,0,10"/>
                
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Plata:" FontWeight="SemiBold" Foreground="#2d3436"/>
                        <TextBox Text="{Binding SilverThreshold}" Padding="5" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Oro:" FontWeight="SemiBold" Foreground="#2d3436"/>
                        <TextBox Text="{Binding GoldThreshold}" Padding="5" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Platino:" FontWeight="SemiBold" Foreground="#2d3436"/>
                        <TextBox Text="{Binding PlatinumThreshold}" Padding="5" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="Diamante:" FontWeight="SemiBold" Foreground="#2d3436"/>
                        <TextBox Text="{Binding DiamondThreshold}" Padding="5" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9"/>
                    </StackPanel>
                </Grid>

                <Border BorderBrush="#7A6F62" BorderThickness="0,1,0,0" Margin="0,10,0,15"/>

                <TextBlock Text="Seguridad del Supervisor" FontWeight="Bold" Foreground="#2d3436" Margin="0,0,0,10"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nueva Clave:" FontWeight="SemiBold" Foreground="#2d3436"/>
                        <TextBox Text="{Binding SupervisorPassword}" Padding="5" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="PIN de Rescate (4 dígitos):" FontWeight="SemiBold" Foreground="#2d3436"/>
                        <TextBox Text="{Binding RecoveryPin}" Padding="5" MaxLength="4" Background="#FFE5E5E5" Foreground="Black" BorderBrush="#dfe6e9"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Guardar Todos los Cambios" Command="{Binding SaveCommand}" 
                Background="#FF0984E3" Foreground="White" FontWeight="Bold" Height="35" Margin="0,15,0,0"/>
    </Grid>
</Window>